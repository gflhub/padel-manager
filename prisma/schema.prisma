// Prisma schema for Padel Manager
// Learn more at https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider  = "postgresql"
}

// ============================================================================
// ENUMS
// ============================================================================

/// Global user role for authentication and authorization
enum GlobalRole {
  ADMIN
  STAFF
  CLIENT
}

/// Staff role within a specific club
enum ClubStaffRole {
  OWNER
  MANAGER
  STAFF
}

/// Court status for availability tracking
enum CourtStatus {
  ACTIVE
  MAINTENANCE
  INACTIVE
}

/// Reservation status throughout its lifecycle
enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

/// Product category for organization
enum ProductCategory {
  bebidas
  lanches
  doces
  outros
}

/// Comanda (order/tab) status for payment tracking
enum ComandaStatus {
  OPEN
  CLOSED
  CANCELLED
}

/// Payment method used for transactions
enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  PIX
  OTHER
}

/// Tournament status throughout its lifecycle
enum TournamentStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

/// Tournament registration status for participants
enum RegistrationStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

/// Monthly-member subscription status
enum SubscriptionStatus {
  ACTIVE
  OVERDUE
  CANCELLED
}

/// Payment status for a closed comanda
enum ComandaPaymentStatus {
  PAID
  RECEIVABLE
}

// ============================================================================
// CORE AUTH MODELS
// ============================================================================

/// User account with global authentication and role information
model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String     @unique
  passwordHash String
  globalRole   GlobalRole @default(CLIENT)
  active       Boolean    @default(true)
  tokenVersion Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  profile      Profile?
  sessions     Session[]
  clubStaff    ClubStaff[]
  reservations Reservation[]
  tournaments  TournamentRegistration[]
  subscriptions Subscription[]

  @@index([email])
  @@index([globalRole])
}

/// User profile with personal information
model Profile {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @db.Uuid
  name      String
  email     String
  phone     String?
  cpf       String?  @unique
  avatarUrl String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  clubStaff    ClubStaff[]
  reservations Reservation[]
  comandasAsCustomer    Comanda[]    @relation("ComandaCustomer")
  settlementsAsCustomer Settlement[] @relation("CustomerSettlements")
  settlementsAsStaff    Settlement[] @relation("StaffSettlements")

  @@index([userId])
  @@index([email])
}

/// Session for managing user authentication tokens
model Session {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  refreshTokenHash String
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  lastUsedAt       DateTime?
  userAgent        String?
  ipAddress        String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ============================================================================
// CLUB MANAGEMENT MODELS
// ============================================================================

/// Club entity for organizing staff and courts
model Club {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trialStartedAt          DateTime?
  trialEndsAt             DateTime?
  trialWarningEmailSentAt DateTime?

  staff         ClubStaff[]
  courts        Court[]
  products      Product[]
  comandas      Comanda[]
  tournaments   Tournament[]
  settings      ClubSettings?
  subscriptions Subscription[]
  settlements   Settlement[]

  @@index([active])
}

/// Club-wide settings (complex info, reservation policies, payment options)
model ClubSettings {
  id                  String   @id @default(uuid()) @db.Uuid
  clubId              String   @unique @db.Uuid
  complexName         String?
  complexAddress      String?
  complexPhone        String?
  complexEmail        String?
  maxAdvanceDays      Int      @default(30)
  defaultSlotDuration Int      @default(90)
  allowPayLater       Boolean  @default(true)
  allowCredits        Boolean  @default(true)
  pixKey              String?
  updatedBy           String?  @db.Uuid
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId])
}

/// Staff member role within a specific club
model ClubStaff {
  id        String        @id @default(uuid()) @db.Uuid
  profileId String        @db.Uuid
  clubId    String        @db.Uuid
  role      ClubStaffRole
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  club    Club    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])
  userId  String? @db.Uuid

  @@unique([profileId, clubId])
  @@index([clubId])
  @@index([active])
}

// ============================================================================
// COURT & RESERVATION MODELS
// ============================================================================

/// Court at a club for hosting reservations
model Court {
  id           String      @id @default(uuid()) @db.Uuid
  clubId       String      @db.Uuid
  name         String
  type         String
  pricePerSlot Decimal     @default(0) @db.Decimal(10, 2)
  durationSlot Int         @default(60)
  status       CourtStatus @default(ACTIVE)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  club         Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  reservations Reservation[]

  @@index([clubId])
  @@index([status])
}

/// Reservation of a court by a user
model Reservation {
  id        String            @id @default(uuid()) @db.Uuid
  courtId   String            @db.Uuid
  profileId String            @db.Uuid
  date      DateTime
  startTime String
  endTime   String
  players   Json?
  pricePerHour Decimal?      @db.Decimal(10, 2)
  totalPrice Decimal?         @db.Decimal(10, 2)
  status    ReservationStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  court   Court   @relation(fields: [courtId], references: [id], onDelete: Cascade)
  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])
  userId  String? @db.Uuid

  @@index([courtId])
  @@index([profileId])
  @@index([date])
  @@index([status])
}

// ============================================================================
// PRODUCTS & COMANDAS MODELS
// ============================================================================

/// Product available for purchase
model Product {
  id        String          @id @default(uuid()) @db.Uuid
  clubId    String          @db.Uuid
  name      String
  category  ProductCategory
  price     Decimal         @db.Decimal(10, 2)
  stock     Int             @default(0)
  available Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  club         Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  comandaItems ComandaItem[]

  @@index([clubId])
  @@index([category])
  @@index([available])
}

/// Comanda (order/tab) for tracking purchases
model Comanda {
  id                String               @id @default(uuid()) @db.Uuid
  clubId            String               @db.Uuid
  number            Int
  customerName      String?              @db.VarChar(255)
  customerProfileId String?              @db.Uuid
  paymentStatus     ComandaPaymentStatus?
  settlementId      String?              @db.Uuid
  status            ComandaStatus        @default(OPEN)
  total             Decimal              @default(0) @db.Decimal(10, 2)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  club            Club        @relation(fields: [clubId], references: [id], onDelete: Cascade)
  items           ComandaItem[]
  payments        Payment[]
  customerProfile Profile?    @relation("ComandaCustomer", fields: [customerProfileId], references: [id], onDelete: SetNull)
  settlement      Settlement? @relation(fields: [settlementId], references: [id], onDelete: SetNull)

  @@unique([clubId, number])
  @@index([clubId])
  @@index([status])
  @@index([clubId, paymentStatus])
  @@index([customerProfileId])
}

/// Item within a comanda
model ComandaItem {
  id        String   @id @default(uuid()) @db.Uuid
  comandaId String   @db.Uuid
  productId String?  @db.Uuid
  name      String?
  quantity  Int
  unitPrice Decimal  @db.Decimal(10, 2)
  subtotal  Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comanda Comanda  @relation(fields: [comandaId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([comandaId])
  @@index([productId])
}

// ============================================================================
// PAYMENT MODELS
// ============================================================================

/// Payment transaction for a comanda
model Payment {
  id        String        @id @default(uuid()) @db.Uuid
  comandaId String        @db.Uuid
  method    PaymentMethod
  amount    Decimal       @db.Decimal(10, 2)
  paidAt    DateTime      @default(now())
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  comanda Comanda @relation(fields: [comandaId], references: [id], onDelete: Cascade)

  @@index([comandaId])
  @@index([paidAt])
}

// ============================================================================
// SETTLEMENT MODELS
// ============================================================================

/// Settlement record when a customer pays off their receivable comandas
model Settlement {
  id                String        @id @default(uuid()) @db.Uuid
  clubId            String        @db.Uuid
  customerProfileId String        @db.Uuid
  totalAmount       Decimal       @db.Decimal(10, 2)
  method            PaymentMethod
  comandasCount     Int
  settledAt         DateTime      @default(now())
  settledBy         String        @db.Uuid
  invoiceIssued     Boolean       @default(false)
  createdAt         DateTime      @default(now())

  club             Club       @relation(fields: [clubId], references: [id], onDelete: Cascade)
  customerProfile  Profile    @relation("CustomerSettlements", fields: [customerProfileId], references: [id], onDelete: Restrict)
  settledByProfile Profile    @relation("StaffSettlements", fields: [settledBy], references: [id], onDelete: Restrict)
  comandas         Comanda[]

  @@index([clubId])
  @@index([clubId, customerProfileId])
}

// ============================================================================
// TOURNAMENT MODELS
// ============================================================================

/// Tournament event at a club
model Tournament {
  id              String           @id @default(uuid()) @db.Uuid
  clubId          String           @db.Uuid
  name            String
  description     String?
  startDate       DateTime
  endDate         DateTime
  maxParticipants Int
  entryFee        Decimal?         @db.Decimal(10, 2)
  status          TournamentStatus @default(DRAFT)
  createdBy       String           @db.Uuid
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  club          Club                     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  registrations TournamentRegistration[]

  @@index([clubId])
  @@index([status])
  @@index([startDate])
}

/// Registration of a user in a tournament
model TournamentRegistration {
  id           String             @id @default(uuid()) @db.Uuid
  tournamentId String             @db.Uuid
  userId       String             @db.Uuid
  registeredAt DateTime           @default(now())
  cancelledAt  DateTime?
  status       RegistrationStatus @default(PENDING)

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId])
  @@index([tournamentId])
  @@index([userId])
  @@index([status])
}

// ============================================================================
// MONTHLY MEMBER (SUBSCRIPTION) MODELS
// ============================================================================

/// Monthly-member subscription plan for a user at a club
model Subscription {
  id          String             @id @default(uuid()) @db.Uuid
  userId      String             @db.Uuid
  clubId      String             @db.Uuid
  planName    String
  price       Decimal            @db.Decimal(10, 2)
  dueDay      Int
  status      SubscriptionStatus @default(ACTIVE)
  nextDueDate DateTime
  dueWarningEmailSentAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@index([userId])
  @@index([status])
  @@index([nextDueDate])
}
